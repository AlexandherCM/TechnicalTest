@using App.ViewModels
@using System.Linq
@model IEnumerable<PersonaViewModel>

@{
    ViewBag.Title = "Registros";
}

<h2>Registros</h2>

<div class="container" style="margin-top: 30px;">

    <div class="row">
        <div class="col-md-12">

            <div class="panel panel-primary">
                <div class="panel-heading">
                    <h3 class="panel-title">Personas registradas</h3>
                </div>

                <div class="panel-body">

                    <p class="text-muted">
                        Consulta de personas registradas en la base de datos.
                    </p>

                    <div class="form-group">
                        <a href="@Url.Action("Registro", "Persona")" class="btn btn-primary">
                            Nuevo registro
                        </a>
                    </div>

                    @if (Model == null || !Model.Any())
                    {
                        <div class="alert alert-warning">
                            No existen personas registradas.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>UserID</th>
                                        <th>Nombre completo</th>
                                        <th>Hobby</th>
                                        <th>Fecha de nacimiento</th>
                                        <th>Correo</th>
                                        <th>Preposiciones</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @foreach (var persona in Model)
                                    {
                                        <tr>
                                            <td>@persona.ID</td>
                                            <td>@persona.UserID</td>
                                            <td>@persona.NombreCompleto</td>
                                            <td>@persona.Hobby</td>
                                            <td>@persona.FechaNacimientoStr</td>
                                            <td>@persona.Correo</td>
                                            <td>@persona.Preposiciones</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                </div>
            </div>

        </div>
    </div>

</div>