@{
    ViewBag.Title = "Cp";
}

<h2>Códigos Postales</h2>

<div class="container" style="margin-top: 30px;">

    <div class="row">
        <div class="col-md-8 col-md-offset-2">

            <div class="panel panel-primary">
                <div class="panel-heading">
                    <h3 class="panel-title">
                        Consulta de Código Postal
                    </h3>
                </div>

                <div class="panel-body">

                    <p class="text-muted">
                        Ingresa un Código Postal de 5 dígitos para consultar la información del estado y sus colonias.
                    </p>

                    <form id="formConsultaCP">

                        <div class="form-group">
                            <label for="txtcodigoPostal">Código Postal</label>

                            <input type="text"
                                   id="txtcodigoPostal"
                                   name="codigoPostal"
                                   class="form-control"
                                   placeholder="Ejemplo: 01000"
                                   maxlength="5"
                                   autocomplete="off" />

                            <span id="mensajeValidacion" class="help-block text-danger" style="display:none;">
                                El código postal debe contener exactamente 5 números.
                            </span>
                        </div>

                        <button type="submit"
                                id="btnConsultar"
                                class="btn btn-primary"
                                disabled>
                            Consultar
                        </button>

                        <button type="button"
                                id="btnLimpiar"
                                class="btn btn-default">
                            Limpiar
                        </button>

                    </form>

                </div>
            </div>

            <div id="seccionResultados" class="panel panel-default" style="display:none;">
                <div class="panel-heading">
                    <h3 class="panel-title">
                        Resultados de la consulta
                    </h3>
                </div>

                <div class="panel-body">

                    <div class="row">
                        <div class="col-md-6">
                            <label>Nombre del estado</label>
                            <p id="lblNombreEstado" class="form-control-static">-</p>
                        </div>

                        <div class="col-md-6">
                            <label>Código del estado</label>
                            <p id="lblCodigoEstado" class="form-control-static">-</p>
                        </div>
                    </div>

                    <hr />

                    <div class="form-group">
                        <label for="ddlColonias">Colonias asociadas al Código Postal</label>

                        <select id="ddlColonias" class="form-control" disabled>
                            <option value="">Seleccione una colonia</option>
                        </select>
                    </div>

                    <div id="contenedorCodigoColonia" class="alert alert-info" style="display:none;">
                        <strong>Código de colonia:</strong>
                        <span id="lblCodigoColonia">-</span>
                    </div>

                </div>
            </div>

            <div id="mensajeSinResultados" class="alert alert-warning" style="display:none;">
                No se encontró información para el Código Postal capturado.
            </div>

            <div id="mensajeErrorConsulta" class="alert alert-danger" style="display:none;">
                Ocurrió un error al consultar la información. Intenta nuevamente.
            </div>


        </div>
    </div>

</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
    @Scripts.Render("~/Scripts/ViewsScripts/PostalCodeScripts/ValidateCpScript.js")
    @Scripts.Render("~/Scripts/ViewsScripts/PostalCodeScripts/RequestCpScript.js")
}